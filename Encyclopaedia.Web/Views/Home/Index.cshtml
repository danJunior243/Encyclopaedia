@model Encyclopaedia.Web.Models.HomeViewModel

@{
    ViewData["Title"] = "Accueil";
}

<!-- ── HERO ── -->
<section class="hero">
    <div class="hero-bg" style="background-image: url('https://images.unsplash.com/photo-1481627834876-b7833e8f5570?w=1600&q=80')"></div>
    <div class="hero-content">
        <div class="hero-badge">📚 Encyclopédie de référence</div>
        <h1 class="hero-title">Explorez la connaissance<br><span class="hero-title-accent">sans limites</span></h1>
        <p class="hero-subtitle">Des milliers d'articles sur les Sciences, l'Histoire et la Nature — rédigés avec rigueur et passion</p>
        <form class="hero-search" asp-controller="Search" asp-action="Index" method="get">
            <input type="text" name="q" placeholder="Rechercher un article, un concept, une découverte…" class="hero-search-input" />
            <button type="submit" class="hero-search-btn">Rechercher</button>
        </form>
        <div class="hero-stats">
            <div class="hero-stat">
                <span class="hero-stat-num">@ViewBag.TotalArticles</span>
                <span class="hero-stat-label">Articles</span>
            </div>
            <div class="hero-stat-divider"></div>
            <div class="hero-stat">
                <span class="hero-stat-num">3</span>
                <span class="hero-stat-label">Domaines</span>
            </div>
            <div class="hero-stat-divider"></div>
            <div class="hero-stat">
                <span class="hero-stat-num">3</span>
                <span class="hero-stat-label">Langues</span>
            </div>
        </div>
    </div>
</section>
<!-- ── DOMAINES ── -->
<section class="domains-section">
    <div class="container">
        <h2 class="section-title">Explorer par domaine</h2>
        <div class="domains-grid">
            <a class="domain-card sciences" asp-controller="Domain" asp-action="Index" asp-route-slug="sciences">
                <div class="domain-card-icon">🔬</div>
                <div class="domain-card-name">Sciences</div>
                <div class="domain-card-desc">Biologie, Physique, Chimie, Astronomie…</div>
            </a>
            <a class="domain-card histoire" asp-controller="Domain" asp-action="Index" asp-route-slug="histoire">
                <div class="domain-card-icon">📜</div>
                <div class="domain-card-name">Histoire</div>
                <div class="domain-card-desc">Civilisations, Guerres, Personnages…</div>
            </a>
            <a class="domain-card nature" asp-controller="Domain" asp-action="Index" asp-route-slug="nature">
                <div class="domain-card-icon">🌿</div>
                <div class="domain-card-name">Nature</div>
                <div class="domain-card-desc">Faune, Flore, Écosystèmes…</div>
            </a>
        </div>
    </div>
</section>


<!-- ── ARTICLES EN VEDETTE ── -->
<section class="featured-section">
    <div class="container">
        <div class="section-header">
            <h2 class="section-title">Articles récents</h2>
            <p class="section-subtitle">Les derniers articles publiés dans notre encyclopédie</p>
        </div>
        <div class="featured-grid">
            <div class="featured-main">
                @if (Model.RecentArticles.Any())
                {
                    var first = Model.RecentArticles.First();
                    var firstTranslation = first.Translations.FirstOrDefault();
                    var firstDomain = first.Category.Domain.Translations.FirstOrDefault(t => t.LanguageId == 1)?.Name ?? first.Category.Domain.Slug;
                    <div class="article-card-big">
                        <div class="article-card-meta">
                            <span class="article-domain">@firstDomain.ToUpper()</span>
                            <span class="article-views">👁 @first.ViewCount vues</span>
                        </div>
                        <h3 class="article-card-title">@firstTranslation?.Title</h3>
                        <p class="article-card-excerpt">@firstTranslation?.Summary</p>
                        <a asp-controller="Article" asp-action="Index"
                           asp-route-slug="@firstTranslation?.Slug"
                           class="article-card-link">Lire l'article →</a>
                    </div>
                }
                else
                {
                    <div class="article-card-big">
                        <p style="color:var(--text-dim)">Aucun article publié pour l'instant.</p>
                    </div>
                }
            </div>
            <div class="featured-side">
                @foreach (var article in Model.RecentArticles.Skip(1).Take(3))
                {
                    var translation = article.Translations.FirstOrDefault();
                    var domainName = article.Category.Domain.Translations.FirstOrDefault(t => t.LanguageId == 1)?.Name ?? article.Category.Domain.Slug;
                    <div class="article-card-small">
                        <div class="article-card-domain sciences-text">@domainName.ToUpper()</div>
                        <h3 class="article-card-title-sm">@translation?.Title</h3>
                        <a asp-controller="Article" asp-action="Index"
                           asp-route-slug="@translation?.Slug"
                           class="article-card-link">Lire →</a>
                    </div>
                }
            </div>
        </div>
    </div>
</section>

<!-- ── LE SAVIEZ-VOUS ── -->
@if (ViewBag.RandomArticle != null)
{
    <section class="did-you-know">
        <div class="container">
            <div class="dyk-inner">
                <div class="dyk-icon">💡</div>
                <div class="dyk-content">
                    <div class="dyk-label">Le saviez-vous ?</div>
                    <p class="dyk-text">@ViewBag.RandomSummary</p>
                    <a class="dyk-link" asp-controller="Article" asp-action="Index"
                       asp-route-slug="@ViewBag.RandomSlug">
                        Lire l'article complet →
                    </a>
                </div>
            </div>
        </div>
    </section>
}