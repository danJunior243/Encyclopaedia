@model Encyclopaedia.Web.Models.ArticleCreateViewModel

@{
    ViewData["Title"] = "Nouvel article";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="admin-wrapper">

    <!-- ── TITRE ── -->
    <div class="admin-header">
        <h1 class="admin-title">Nouvel article</h1>
        <p class="admin-subtitle">Créer un nouvel article</p>
    </div>

    <form asp-action="Create" method="post">
        @if (!ViewData.ModelState.IsValid)
        {
            <div asp-validation-summary="All" class="login-error"></div>
        }
        <div class="admin-section">
            <div class="form-row">
                <div class="form-group">
                    <label asp-for="Title">Titre</label>
                    <input asp-for="Title" type="text" placeholder="Titre de l'article" />
                    <span asp-validation-for="Title" class="field-error"></span>
                </div>
                <div class="form-group">
                    <label asp-for="LanguageId">Langue</label>
                    <select asp-for="LanguageId" asp-items="Model.Languages">
                        <option value="">-- Choisir une langue --</option>
                    </select>
                    <span asp-validation-for="LanguageId" class="field-error"></span>
                </div>
            </div>

            <div class="form-group">
                <label asp-for="CategoryId">Catégorie</label>
                <select asp-for="CategoryId" asp-items="Model.Categories">
                    <option value="">-- Choisir une catégorie --</option>
                </select>
                <span asp-validation-for="CategoryId" class="field-error"></span>
            </div>

            <div class="form-group">
                <label asp-for="Summary">Résumé</label>
                <textarea asp-for="Summary" rows="3" placeholder="Bref résumé de l'article…"></textarea>
                <span asp-validation-for="Summary" class="field-error"></span>
            </div>

            <div class="form-group">
                <label asp-for="FeaturedImage">Image principale (URL)</label>
                <input asp-for="FeaturedImage" type="text" placeholder="https://images.unsplash.com/..." />
                <small style="color:var(--text-dim); font-size:0.78rem;">
                    Collez une URL d'image depuis Unsplash ou autre source libre de droits
                </small>
            </div>

            <div class="form-group">
                <label asp-for="Content">Contenu</label>
                <textarea asp-for="Content" rows="12" placeholder="Contenu de l'article…"></textarea>
                <span asp-validation-for="Content" class="field-error"></span>
            </div>
        </div>

        <div style="display:flex; gap:1rem; justify-content:flex-end; margin-top:1rem;">
            <a asp-action="Index" class="btn-admin-cancel">Annuler</a>
            <button type="submit" class="btn-admin-add">Enregistrer</button>
        </div>

    </form>

</div>