<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Admin | Encyclopædia</title>
    <link href="https://fonts.googleapis.com/css2?family=Lora:ital,wght@0,400;0,600;0,700;1,400&family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <script src="https://unpkg.com/tinymce@6/tinymce.min.js" referrerpolicy="origin"></script>
</head>
<body class="admin-body">

    <div class="admin-layout">

        <!-- ── SIDEBAR ── -->
        <aside class="admin-sidebar">
            <div class="sidebar-logo">Encyclopædia</div>
            <div class="sidebar-subtitle">Administration</div>

            <nav class="sidebar-nav">
                <a class="sidebar-link" asp-controller="Dashboard" asp-action="Index">
                    📊 Dashboard
                </a>
                <a class="sidebar-link" asp-controller="AdminArticle" asp-action="Index">
                    📝 Articles
                </a>
                <a class="sidebar-link" asp-controller="AdminCategory" asp-action="Index">
                    📁 Catégories
                </a>
                <a class="sidebar-link" asp-controller="AdminDomain" asp-action="Index">
                    🌐 Domaines
                </a>
                <a class="sidebar-link" asp-controller="User" asp-action="Index">
                    👥 Utilisateurs
                </a>
            </nav>

            <div class="sidebar-footer">
                <a class="sidebar-link" asp-controller="Home" asp-action="Index">
                    ← Voir le site
                </a>
                <a class="sidebar-link" asp-controller="Account" asp-action="Logout">
                    🚪 Déconnexion
                </a>

                <a class="sidebar-link" asp-controller="Import" asp-action="Index">
                    ⬆️ Importer
                </a>

            </div>
        </aside>

        <!-- ── CONTENU ── -->
        <div class="admin-content">
            @RenderBody()
        </div>

    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)

</body>
</html>