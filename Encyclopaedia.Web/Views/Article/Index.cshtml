@model Encyclopaedia.Core.Entities.ArticleTranslation

@{
    ViewData["Title"] = Model.Title;
    var domainName = Model.Article.Category.Domain.Translations
        .FirstOrDefault(t => t.LanguageId == 1)?.Name ?? Model.Article.Category.Domain.Slug;
    var catName = Model.Article.Category.Translations
        .FirstOrDefault(t => t.LanguageId == 1)?.Name ?? Model.Article.Category.Slug;
}

<div class="article-page">

    <!-- ── BREADCRUMB ── -->
    <div class="breadcrumb">
        <a asp-controller="Home" asp-action="Index">Accueil</a>
        <span>›</span>
        <a asp-controller="Domain" asp-action="Index" asp-route-slug="@Model.Article.Category.Domain.Slug">
            @domainName
        </a>
        <span>›</span>
        <a asp-controller="Category" asp-action="Index" asp-route-slug="@Model.Article.Category.Slug">
            @catName
        </a>
        <span>›</span>
        <span>@Model.Title</span>
    </div>

    <!-- ── CONTENU ── -->
    <div class="article-container">

        <!-- ── ARTICLE PRINCIPAL ── -->
        <article class="article-main">
            <!--Si l'image existe on l'affiche -->
            @{

                var imageUrl = !string.IsNullOrEmpty(Model.Article.FeaturedImage)
                ? Model.Article.FeaturedImage
                : Model.Article.Category.Domain.Slug switch
                {
                    "sciences" => "https://images.unsplash.com/photo-1507413245164-6160d8298b31?w=1200&q=80",
                    "histoire" => "https://images.unsplash.com/photo-1461360370896-922624d12aa1?w=1200&q=80",
                    "nature" => "https://images.unsplash.com/photo-1441974231531-c6227db76b6e?w=1200&q=80",
                    _ => "https://images.unsplash.com/photo-1481627834876-b7833e8f5570?w=1200&q=80"
                };
                
            }

            <div class="article-featured-image">
                <img src="@imageUrl" alt="@Model.Title" />
            </div>

            <div class="article-meta">
                <span class="article-domain">@domainName.ToUpper()</span>
                <span class="article-category">@catName</span>
                <span class="article-views">👁 @Model.Article.ViewCount vues</span>
            </div>

            <h1 class="article-title">@Model.Title</h1>

            <div class="article-summary">
                @Model.Summary
            </div>

            <div class="article-divider"></div>

            <div class="article-content">
                @Html.Raw(Model.Content)
            </div>

            <!-- ── PARTAGER ── -->
            <div class="article-share">
                <span class="article-share-label">Partager :</span>
                <a class="share-btn" href="https://twitter.com/intent/tweet?text=@Model.Title" target="_blank">𝕏</a>
                <a class="share-btn" href="https://www.facebook.com/sharer/sharer.php?u=@Context.Request.Path" target="_blank">f</a>
            </div>

        </article>

        <!-- ── SIDEBAR ── -->
        <aside class="article-sidebar">

            <!-- Informations -->
            <div class="sidebar-card">
                <div class="sidebar-card-title">Informations</div>
                <div class="sidebar-info">
                    <span class="sidebar-info-label">Domaine</span>
                    <span class="sidebar-info-value">@domainName</span>
                </div>
                <div class="sidebar-info">
                    <span class="sidebar-info-label">Catégorie</span>
                    <span class="sidebar-info-value">@catName</span>
                </div>
                <div class="sidebar-info">
                    <span class="sidebar-info-label">Langue</span>
                    <span class="sidebar-info-value">@Model.Language.Name</span>
                </div>
                <div class="sidebar-info">
                    <span class="sidebar-info-label">Vues</span>
                    <span class="sidebar-info-value">@Model.Article.ViewCount</span>
                </div>
            </div>

            <!-- Articles similaires -->
            @if (ViewBag.SimilarArticles != null)
            {
                <div class="sidebar-card" style="margin-top:1rem;">
                    <div class="sidebar-card-title">Articles similaires</div>
                    @foreach (var similar in ViewBag.SimilarArticles as List<Encyclopaedia.Core.Entities.ArticleTranslation>)
                    {
                        <a class="similar-article" asp-controller="Article"
                           asp-action="Index" asp-route-slug="@similar.Slug">
                            @similar.Title
                        </a>
                    }
                </div>
            }

        </aside>

    </div>

</div>