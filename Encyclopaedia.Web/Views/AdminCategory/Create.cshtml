@model Encyclopaedia.Web.Models.CategoryViewModel

@{
    ViewData["Title"] = "Nouvelle catégorie";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="admin-wrapper">

    <!-- ── TITRE ── -->
    <div class="admin-header">
        <h1 class="admin-title">Nouvelle catégorie</h1>
        <p class="admin-subtitle">Créer une nouvelle catégorie</p>
    </div>

    <form asp-controller="AdminCategory" asp-action="Create" method="post">
        <div asp-validation-summary="All" class="login-error"></div>

        <div class="admin-section">

            <div class="form-row">
                <div class="form-group">
                    <label asp-for="DomainId">Domaine</label>
                    <select asp-for="DomainId" asp-items="Model.Domains">
                        <option value="">-- Choisir un domaine --</option>
                    </select>
                    <span asp-validation-for="DomainId" class="field-error"></span>
                </div>
                <div class="form-group">
                    <label asp-for="ParentId">Catégorie parente (optionnel)</label>
                    <select asp-for="ParentId" asp-items="Model.ParentCategories">
                        <option value="">-- Aucune (catégorie racine) --</option>
                    </select>
                </div>
            </div>

            <div class="form-row">
                <div class="form-group">
                    <label asp-for="Slug">Slug (URL)</label>
                    <input asp-for="Slug" type="text" placeholder="ex: biologie" />
                    <span asp-validation-for="Slug" class="field-error"></span>
                </div>
                <div class="form-group">
                    <label asp-for="SortOrder">Ordre d'affichage</label>
                    <input asp-for="SortOrder" type="number" />
                </div>
            </div>

            <div class="form-row">
                <div class="form-group">
                    <label asp-for="NameFr">Nom en Français</label>
                    <input asp-for="NameFr" type="text" placeholder="ex: Biologie" />
                    <span asp-validation-for="NameFr" class="field-error"></span>
                </div>
                <div class="form-group">
                    <label asp-for="NameEn">Nom en Anglais</label>
                    <input asp-for="NameEn" type="text" placeholder="ex: Biology" />
                </div>
            </div>

            <div class="form-group">
                <label asp-for="NameAr">Nom en Arabe</label>
                <input asp-for="NameAr" type="text" placeholder="ex: علم الأحياء" />
            </div>

        </div>

        <div style="display:flex; gap:1rem; justify-content:flex-end; margin-top:1rem;">
            <a asp-controller="AdminCategory" asp-action="Index" class="btn-admin-cancel">Annuler</a>
            <button type="submit" class="btn-admin-add">Enregistrer</button>
        </div>

    </form>

</div>